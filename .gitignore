# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit these
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript build info
*.tsbuildinfo
next-env.d.ts

# prisma — generated client and sqlite database
/lib/generated/prisma
*.db
*.db-journal
prisma/*.db

# fonts loaded at runtime
Lora-Regular.ttf

# uploaded files (user data — should not be in source control)
/public/uploads/

# developer-only scripts
/scripts/dev/
