# ============================================================
# INVOFOX 2.0 — ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your values.
# ⚠️  NEVER commit .env to version control.
# ============================================================

# --- DATABASE ---
# SQLite (default, great for single-user and development):
DATABASE_URL="file:./dev.db"

# For a production multi-user deployment, use PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/invofox"
# (Also change prisma/schema.prisma datasource provider to "postgresql")

# --- AUTHENTICATION ---
# REQUIRED. Generate a secure random secret:
#   openssl rand -base64 32
AUTH_SECRET=""

# The URL where this application is hosted (no trailing slash).
NEXTAUTH_URL="http://localhost:3000"

# --- EMAIL (ZeptoMail) ---
# Set your real API token here to enable actual email delivery.
# Leave blank to run in Sandbox Mode (emails are logged but NOT sent).
# These settings can also be configured via Settings > Email API in the UI.
ZEPTOMAIL_API_URL="api.zeptomail.com/"
ZEPTOMAIL_API_TOKEN=""

# The webhook secret is managed via the Settings UI.
# ZeptoMail will provide this token after you save a webhook URL in their dashboard.
# ZEPTOMAIL_WEBHOOK_SECRET=""

# --- CRON / AUTOMATION ---
# Used to secure POST /api/reminders/process for external cron schedulers
# (e.g. cron-job.org, Render crons, GitHub Actions scheduled workflows).
# Generate with: openssl rand -base64 32
# Leave blank if you will only trigger reminders manually from the UI.
CRON_SECRET=""

# --- MULTI-TENANCY ---
# Identifies the two organizations in this deployment.
# Change these to your own values when deploying for a new organization.
#
# PRIMARY_COMPANY is the main internal team (Owners, Managers, Workers).
# VENDOR_COMPANY  is the external partner/vendor team (VendorManager, VendorWorker).
#
PRIMARY_COMPANY="blackfox"
VENDOR_COMPANY="frameit"
